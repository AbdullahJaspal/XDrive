# Copy to apps/web/.env for local development

DATABASE_URL=postgresql://phv:phv_dev_password@localhost:5432/phv_platform?schema=public

JWT_ACCESS_SECRET=change-me-min-32-chars-access-secret-dev-only
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret-dev-only
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BOOKING_RETENTION_YEARS=2
STORAGE_LOCAL_PATH=./uploads

# Guest web bookings (operator UUID or licence number, e.g. WLV-DEV-001)
PUBLIC_OPERATOR_ID=WLV-DEV-001

# Canonical site URL for Open Graph metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Pusher for live dispatch (see apps/web/.env.example)
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=eu
# PUSHER_APP_ID=
# PUSHER_SECRET=
