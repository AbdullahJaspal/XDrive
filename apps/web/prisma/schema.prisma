// UK PHV Operator Platform — Prisma Schema Foundation
// Wolverhampton Council PHV compliance: booking retention, licence tracking, audit trails

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  OPERATOR_ADMIN
  DISPATCHER
  COMPLIANCE_OFFICER
  CUSTOMER
  DRIVER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DEACTIVATED
}

enum DriverStatus {
  PENDING_APPROVAL
  ACTIVE
  OFF_DUTY
  ON_DUTY
  ON_TRIP
  SUSPENDED
  DEACTIVATED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  SUSPENDED
  DECOMMISSIONED
}

enum BookingStatus {
  DRAFT
  REQUESTED
  CONFIRMED
  DISPATCHED
  DRIVER_EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WEB
  MOBILE
  PHONE
  OPERATOR
  API
}

enum AccessibilityRequirement {
  WHEELCHAIR_ACCESSIBLE
  ASSISTANCE_DOG
  HEARING_LOOP
  STEP_FREE
  LARGE_PRINT_RECEIPT
  OTHER
}

enum LicenceType {
  PHV_DRIVER
  PHV_VEHICLE
  OPERATOR
  DVLA_DRIVING
}

enum LicenceStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
  REVOKED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
  CANCELLED
}

enum ComplaintStatus {
  OPEN
  UNDER_INVESTIGATION
  RESOLVED
  ESCALATED
  CLOSED
}

enum SafeguardingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SafeguardingStatus {
  REPORTED
  UNDER_REVIEW
  REFERRED
  CLOSED
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  DISPATCH
  EXPORT
  LOGIN
  LOGOUT
}

enum FileEntityType {
  DRIVER_LICENCE
  VEHICLE_LICENCE
  INSURANCE
  COMPLAINT_EVIDENCE
  SAFEGUARDING_EVIDENCE
  PROFILE_PHOTO
  OTHER
}

enum DispatchAction {
  ASSIGN_DRIVER
  REASSIGN
  AUTO_DISPATCH
  MANUAL_DISPATCH
  CANCEL_DISPATCH
  STATUS_UPDATE
}

// =============================================================================
// OPERATOR (licence holder — Wolverhampton PHV)
// =============================================================================

model Operator {
  id                String   @id @default(uuid()) @db.Uuid
  licenceNumber     String   @unique @map("licence_number")
  legalName         String   @map("legal_name")
  tradingName       String?  @map("trading_name")
  addressLine1      String   @map("address_line1")
  addressLine2      String?  @map("address_line2")
  city              String
  postcode          String
  contactEmail      String   @map("contact_email")
  contactPhone      String   @map("contact_phone")
  bookingRetentionYears Int  @default(2) @map("booking_retention_years")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  users             User[]
  drivers           Driver[]
  vehicles          Vehicle[]
  bookings          Booking[]
  complaints        Complaint[]
  safeguardingReports SafeguardingReport[]
  auditLogs         AuditLog[]
  dispatchLogs      DispatchLog[]

  @@map("operators")
}

// =============================================================================
// USERS & AUTH
// =============================================================================

model User {
  id            String     @id @default(uuid()) @db.Uuid
  operatorId    String?    @map("operator_id") @db.Uuid
  email         String     @unique
  passwordHash  String     @map("password_hash")
  firstName     String     @map("first_name")
  lastName      String     @map("last_name")
  phone         String?
  role          UserRole
  status        UserStatus @default(PENDING_VERIFICATION)
  emailVerified Boolean    @default(false) @map("email_verified")
  lastLoginAt   DateTime?  @map("last_login_at")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  operator      Operator?  @relation(fields: [operatorId], references: [id])
  driver        Driver?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[] @relation("AuditActor")
  notifications Notification[]
  complaintsFiled Complaint[] @relation("ComplaintReporter")

  @@index([operatorId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================================================
// DRIVERS & VEHICLES
// =============================================================================

model Driver {
  id              String       @id @default(uuid()) @db.Uuid
  operatorId      String       @map("operator_id") @db.Uuid
  userId          String       @unique @map("user_id") @db.Uuid
  employeeNumber  String?      @map("employee_number")
  status          DriverStatus @default(PENDING_APPROVAL)
  niNumber        String?      @map("ni_number")
  dateOfBirth     DateTime?    @map("date_of_birth") @db.Date
  addressLine1    String?      @map("address_line1")
  postcode        String?
  emergencyContact String?     @map("emergency_contact")
  emergencyPhone  String?      @map("emergency_phone")
  approvedAt      DateTime?    @map("approved_at")
  suspendedAt     DateTime?    @map("suspended_at")
  suspensionReason String?     @map("suspension_reason")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  operator        Operator     @relation(fields: [operatorId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
  licences        ComplianceDocument[]
  vehicles        DriverVehicle[]
  bookings        Booking[]
  locationSnapshots DriverLocationSnapshot[]
  dispatchLogs    DispatchLog[]

  @@index([operatorId, status])
  @@map("drivers")
}

model Vehicle {
  id              String        @id @default(uuid()) @db.Uuid
  operatorId      String        @map("operator_id") @db.Uuid
  registration    String
  make            String
  model           String
  colour          String
  year            Int?
  seats           Int           @default(4)
  isWheelchairAccessible Boolean @default(false) @map("is_wheelchair_accessible")
  status          VehicleStatus @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  operator        Operator      @relation(fields: [operatorId], references: [id])
  licences        ComplianceDocument[]
  driverAssignments DriverVehicle[]
  bookings        Booking[]

  @@unique([operatorId, registration])
  @@index([operatorId, status])
  @@map("vehicles")
}

model DriverVehicle {
  id         String   @id @default(uuid()) @db.Uuid
  driverId   String   @map("driver_id") @db.Uuid
  vehicleId  String   @map("vehicle_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  assignedAt DateTime @default(now()) @map("assigned_at")
  endedAt    DateTime? @map("ended_at")

  driver  Driver  @relation(fields: [driverId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@unique([driverId, vehicleId])
  @@map("driver_vehicles")
}

model ComplianceDocument {
  id               String        @id @default(uuid()) @db.Uuid
  licenceType      LicenceType   @map("licence_type")
  licenceNumber    String        @map("licence_number")
  issuingAuthority String        @map("issuing_authority")
  issueDate        DateTime?     @map("issue_date") @db.Date
  expiryDate       DateTime      @map("expiry_date") @db.Date
  status           LicenceStatus @default(VALID)
  driverId         String?       @map("driver_id") @db.Uuid
  vehicleId        String?       @map("vehicle_id") @db.Uuid
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  driver           Driver?       @relation(fields: [driverId], references: [id])
  vehicle          Vehicle?      @relation(fields: [vehicleId], references: [id])
  files            StoredFile[]

  @@index([expiryDate, status])
  @@index([driverId])
  @@index([vehicleId])
  @@map("compliance_documents")
}

// =============================================================================
// BOOKINGS & DISPATCH
// =============================================================================

model Booking {
  id                      String   @id @default(uuid()) @db.Uuid
  operatorId              String   @map("operator_id") @db.Uuid
  reference               String   @unique
  status                  BookingStatus @default(REQUESTED)
  source                  BookingSource @default(WEB)
  customerId              String?  @map("customer_id") @db.Uuid
  driverId                String?  @map("driver_id") @db.Uuid
  vehicleId               String?  @map("vehicle_id") @db.Uuid

  pickupAddress           String   @map("pickup_address")
  pickupPostcode          String   @map("pickup_postcode")
  pickupLat               Float    @map("pickup_lat")
  pickupLng               Float    @map("pickup_lng")
  dropoffAddress          String   @map("dropoff_address")
  dropoffPostcode         String   @map("dropoff_postcode")
  dropoffLat              Float    @map("dropoff_lat")
  dropoffLng              Float    @map("dropoff_lng")

  scheduledAt             DateTime? @map("scheduled_at")
  passengerName           String   @map("passenger_name")
  passengerPhone          String   @map("passenger_phone")
  passengerEmail          String?  @map("passenger_email")
  guestAccessToken        String?  @unique @map("guest_access_token")
  accessibilityRequirements AccessibilityRequirement[] @map("accessibility_requirements")
  notes                   String?
  fareEstimatePence       Int?     @map("fare_estimate_pence")
  fareFinalPence          Int?     @map("fare_final_pence")
  distanceMetres          Int?     @map("distance_metres")
  durationSeconds         Int?     @map("duration_seconds")

  dispatchedAt            DateTime? @map("dispatched_at")
  startedAt               DateTime? @map("started_at")
  completedAt             DateTime? @map("completed_at")
  cancelledAt             DateTime? @map("cancelled_at")
  cancellationReason      String?  @map("cancellation_reason")

  retentionExpiresAt      DateTime? @map("retention_expires_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  operator                Operator @relation(fields: [operatorId], references: [id])
  driver                  Driver?  @relation(fields: [driverId], references: [id])
  vehicle                 Vehicle? @relation(fields: [vehicleId], references: [id])
  statusHistory           BookingStatusHistory[]
  payments                Payment[]
  dispatchLogs            DispatchLog[]
  complaints              Complaint[]

  @@index([operatorId, status, createdAt])
  @@index([driverId])
  @@index([reference])
  @@index([retentionExpiresAt])
  @@map("bookings")
}

model BookingStatusHistory {
  id         String        @id @default(uuid()) @db.Uuid
  bookingId  String        @map("booking_id") @db.Uuid
  fromStatus BookingStatus? @map("from_status")
  toStatus   BookingStatus @map("to_status")
  changedBy  String?       @map("changed_by") @db.Uuid
  reason     String?
  metadata   Json?
  createdAt  DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@map("booking_status_history")
}

model DispatchLog {
  id           String         @id @default(uuid()) @db.Uuid
  operatorId   String         @map("operator_id") @db.Uuid
  bookingId    String         @map("booking_id") @db.Uuid
  driverId     String?        @map("driver_id") @db.Uuid
  action       DispatchAction
  performedBy  String?        @map("performed_by") @db.Uuid
  previousData Json?          @map("previous_data")
  newData      Json?          @map("new_data")
  ipAddress    String?        @map("ip_address")
  userAgent    String?        @map("user_agent")
  createdAt    DateTime       @default(now()) @map("created_at")

  operator Operator @relation(fields: [operatorId], references: [id])
  booking  Booking  @relation(fields: [bookingId], references: [id])
  driver   Driver?  @relation(fields: [driverId], references: [id])

  @@index([bookingId, createdAt])
  @@index([operatorId, createdAt])
  @@map("dispatch_logs")
}

model DriverLocationSnapshot {
  id        String   @id @default(uuid()) @db.Uuid
  driverId  String   @map("driver_id") @db.Uuid
  lat       Float
  lng       Float
  heading   Float?
  speedKmh  Float?   @map("speed_kmh")
  recordedAt DateTime @default(now()) @map("recorded_at")

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, recordedAt])
  @@map("driver_location_snapshots")
}

// =============================================================================
// PAYMENTS
// =============================================================================

model Payment {
  id                String        @id @default(uuid()) @db.Uuid
  bookingId         String        @map("booking_id") @db.Uuid
  stripePaymentId   String?       @unique @map("stripe_payment_id")
  amountPence       Int           @map("amount_pence")
  currency          String        @default("gbp")
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@map("payments")
}

// =============================================================================
// COMPLAINTS & SAFEGUARDING
// =============================================================================

model Complaint {
  id            String          @id @default(uuid()) @db.Uuid
  operatorId    String          @map("operator_id") @db.Uuid
  bookingId     String?         @map("booking_id") @db.Uuid
  reporterId    String?         @map("reporter_id") @db.Uuid
  reference     String          @unique
  status        ComplaintStatus @default(OPEN)
  category      String
  description   String
  resolution    String?
  resolvedAt    DateTime?       @map("resolved_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  operator      Operator        @relation(fields: [operatorId], references: [id])
  booking       Booking?        @relation(fields: [bookingId], references: [id])
  reporter      User?           @relation("ComplaintReporter", fields: [reporterId], references: [id])
  files         StoredFile[]

  @@index([operatorId, status])
  @@map("complaints")
}

model SafeguardingReport {
  id            String               @id @default(uuid()) @db.Uuid
  operatorId    String               @map("operator_id") @db.Uuid
  reference     String               @unique
  severity      SafeguardingSeverity
  status        SafeguardingStatus   @default(REPORTED)
  description   String
  reportedBy    String?              @map("reported_by") @db.Uuid
  bookingId     String?              @map("booking_id") @db.Uuid
  referredTo    String?              @map("referred_to")
  closedAt      DateTime?            @map("closed_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  operator      Operator             @relation(fields: [operatorId], references: [id])
  files         StoredFile[]

  @@index([operatorId, status, severity])
  @@map("safeguarding_reports")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  title     String
  body      String
  payload   Json?
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

// =============================================================================
// AUDIT & FILES
// =============================================================================

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  operatorId   String?     @map("operator_id") @db.Uuid
  actorId      String?     @map("actor_id") @db.Uuid
  action       AuditAction
  resourceType String      @map("resource_type")
  resourceId   String?     @map("resource_id")
  changes      Json?
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  requestId    String?     @map("request_id")
  createdAt    DateTime    @default(now()) @map("created_at")

  operator     Operator?   @relation(fields: [operatorId], references: [id])
  actor        User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([operatorId, createdAt])
  @@index([resourceType, resourceId])
  @@index([actorId])
  @@map("audit_logs")
}

model StoredFile {
  id                    String         @id @default(uuid()) @db.Uuid
  entityType            FileEntityType @map("entity_type")
  entityId              String         @map("entity_id")
  originalName          String         @map("original_name")
  mimeType              String         @map("mime_type")
  sizeBytes             Int            @map("size_bytes")
  storageKey            String         @unique @map("storage_key")
  uploadedBy            String?        @map("uploaded_by") @db.Uuid
  complianceDocumentId  String?        @map("compliance_document_id") @db.Uuid
  complaintId           String?        @map("complaint_id") @db.Uuid
  safeguardingReportId  String?        @map("safeguarding_report_id") @db.Uuid
  createdAt             DateTime       @default(now()) @map("created_at")

  complianceDocument    ComplianceDocument? @relation(fields: [complianceDocumentId], references: [id])
  complaint             Complaint?          @relation(fields: [complaintId], references: [id])
  safeguardingReport    SafeguardingReport? @relation(fields: [safeguardingReportId], references: [id])

  @@index([entityType, entityId])
  @@map("stored_files")
}
