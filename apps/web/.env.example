# Database (Neon, Vercel Postgres, or local Postgres)
# Neon: pooled URL for DATABASE_URL, direct URL for DIRECT_URL (see Neon dashboard)
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require

# JWT (min 32 characters each)
JWT_ACCESS_SECRET=dev-only-change-me-access-secret-32chars-min
JWT_REFRESH_SECRET=dev-only-change-me-refresh-secret-32chars-min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BOOKING_RETENTION_YEARS=2
STORAGE_LOCAL_PATH=./uploads

# Guest web bookings (operator UUID or licence number)
PUBLIC_OPERATOR_ID=WLV-DEV-001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Client API base (default: same-origin /api/v1)
# NEXT_PUBLIC_API_URL=/api/v1

# Pusher Channels (optional — enables live dispatch updates)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu
PUSHER_APP_ID=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
